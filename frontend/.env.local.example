# ESRI Climate Intelligence Platform - Environment Configuration
# Copy this file to .env.local and fill in your actual values

# Google Gemini API Configuration
# Get your API key from: https://cloud.google.com/docs/authentication/api-keys
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Map tile service configuration
# NEXT_PUBLIC_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# Optional: Analytics or monitoring services
# SENTRY_DSN=your_sentry_dsn_here
