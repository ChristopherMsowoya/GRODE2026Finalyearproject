# Copy this file to `.env` and fill in your Supabase credentials.
# Do NOT commit your real `.env` to source control.

# Supabase (server)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key...

# Direct Postgres connection string for migrations and PostGIS queries.
# Supabase: Project Settings -> Database -> Connection string.
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Supabase (public, for frontend)
SUPABASE_ANON_KEY=eyJ...anon_key...

# Frontend public env bindings (Next.js will read these as NEXT_PUBLIC_*)
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
